{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@taukei/domain": ["../domain/src"],
      "@taukei/env": ["../env/src"]
    }
  },
  "include": ["src"]
}
