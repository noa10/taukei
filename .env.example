# Taukei local defaults are safe: no real money movement and no rider booking.
NEXT_PUBLIC_APP_NAME=Taukei
NEXT_PUBLIC_SITE_URL=http://localhost:56778
TAUKEI_STRIPE_MODE=fake
TAUKEI_LALAMOVE_MODE=fake

# Live modes fail closed unless explicitly enabled with credentials in a later production phase.
# TAUKEI_ALLOW_LIVE_INTEGRATIONS=false
# STRIPE_SECRET_KEY=
# LALAMOVE_API_KEY=
# LALAMOVE_API_SECRET=

# Supabase Auth (server-validated by lib/supabase/config.ts; do NOT commit real keys)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
