{
  "name": "taukei",
  "version": "0.1.0",
  "private": true,
  "description": "Taukei web/PWA platform foundation for Malaysian independent food merchants.",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --cwd apps/web dev",
    "build": "bun --cwd apps/web build",
    "lint": "bun --cwd apps/web lint",
    "typecheck": "bun --cwd apps/web typecheck && bun --cwd packages/env typecheck && bun --cwd packages/domain typecheck && bun run typecheck:schema",
    "test": "bun test",
    "test:e2e": "bun run smoke",
    "smoke": "bun run scripts/smoke-startup.ts",
    "verify": "bun run lint && bun run typecheck && bun run test && bun run build",
    "typecheck:schema": "tsc --noEmit -p tsconfig.schema.json",
    "schema:validate": "./scripts/validate-supabase-schema.sh",
    "smoke:customer": "./scripts/smoke-customer-flow.sh",
    "smoke:merchant": "./scripts/smoke-merchant-flow.sh"
  },
  "keywords": [
    "taukei",
    "nextjs",
    "pwa",
    "supabase",
    "stripe",
    "lalamove"
  ],
  "dependencies": {
    "@taukei/env": "workspace:*",
    "@taukei/domain": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
